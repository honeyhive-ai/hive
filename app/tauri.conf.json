{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hive",
  "version": "0.2.0",
  "identifier": "com.hive.desktop",
  "build": {
    "frontendDist": "../web/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "bun run --cwd ../web dev",
    "beforeBuildCommand": "bun run --cwd ../web build"
  },
  "app": {
    "windows": [
      {
        "title": "Hive",
        "width": 1280,
        "height": 832,
        "minWidth": 880,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/honeyhive-ai/hive/releases/latest/download/latest.json"
      ],
      "pubkey": ""
    }
  }
}
